# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PostgreSQL Database Connection URL
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=

# mDirector — Integración de email marketing
# Obtén estas credenciales en: https://app.mdirector.com → Configuración → API
MDIRECTOR_API_KEY=
MDIRECTOR_API_SECRET=
MDIRECTOR_FROM_EMAIL=
MDIRECTOR_FROM_NAME=CanTrack Staffing

# ── Enrichment fallback #1: Groq (gratuito) ──────────────────────────────────
# Crea una clave en: https://console.groq.com/keys
# Plan gratuito: ~14 400 RPM en llama-3.1-8b-instant
# Si no está configurado, se salta este proveedor.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Enrichment fallback #2: Ollama (local, sin internet) ─────────────────────
# Requisito: tener Ollama corriendo → https://ollama.com/download
# El servidor detecta automáticamente si Ollama está disponible.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Orden de fallback automático:
#   1. Gemini  (GEMINI_API_KEY configurado)
#   2. Groq    (GROQ_API_KEY configurado)
#   3. Ollama  (localhost:11434 responde)
#   4. WebSearch (DuckDuckGo + Wikipedia — siempre disponible, datos básicos)

# ── Automatización de aplicaciones ───────────────────────────────────────────
# false = modo simulación (recomendado en producción)
# true  = envía formularios reales con Playwright
AUTOMATION_SUBMIT_ENABLED=false
