# ══════════════════════════════════════════════════════════════════════════════
# CanTrack CRM — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit your .env file to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Security (REQUIRED) ───────────────────────────────────────────────────────
# Strong random secret for signing JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
# PostgreSQL connection string.
# Format: postgresql://user:password@host:port/dbname
# Example with SSH tunnel on port 5434:
#   DATABASE_URL=postgresql://casaos:casaos@127.0.0.1:5434/casaos
DATABASE_URL=


# ── AI Enrichment ─────────────────────────────────────────────────────────────
# Fallback order: Groq → Gemini → Ollama → WebSearch (DuckDuckGo/Wikipedia)

# Primary enrichment: Google Gemini
# Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Enrichment fallback #1: Groq (free ~14 400 RPM)
# Get a key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Enrichment fallback #2: Ollama (local, air-gapped)
# Requires Ollama running locally: https://ollama.com/download
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Email Marketing (mDirector) ───────────────────────────────────────────────
# Get credentials at: https://app.mdirector.com → Settings → API
MDIRECTOR_API_KEY=
MDIRECTOR_API_SECRET=
MDIRECTOR_FROM_EMAIL=
MDIRECTOR_FROM_NAME=CanTrack Staffing

# ── Webhook (scraper integration) ─────────────────────────────────────────────
# Random secret shared with the scraper. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=

# ── Automation ────────────────────────────────────────────────────────────────
# false = simulation mode (recommended). true = submits real forms via Playwright.
AUTOMATION_SUBMIT_ENABLED=false
